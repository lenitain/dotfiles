{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "none"
    },
    "display": {
        "separator": ": "
    },
    "modules": [
        "title",
        "separator",

        {
            "type": "separator",
            "string": "━━ System ━━━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        "os",
        "host",
        "kernel",
        "uptime",
        "packages",
        "shell",
        "locale",
        "break",

        {
            "type": "separator",
            "string": "━━ DE / WM ━━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        "display",
        "brightness",
        "lm",
        "de",
        "wm",
        "wmtheme",
        "theme",
        "icons",
        "font",
        "cursor",
        "terminal",
        "terminalfont",
        "wallpaper",
        "break",

        {
            "type": "separator",
            "string": "━━ Time ━━━━━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        "datetime",
        "break",

        {
            "type": "separator",
            "string": "━━ Hardware ━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        {
            "type": "cpu",
            "showPeCoreCount": true,
            "temp": true
        },
        "cpucache",
        "cpuusage",
        {
            "type": "gpu",
            "driverSpecific": true,
            "temp": true
        },
        "memory",
        "physicalmemory",
        {
            "type": "swap",
            "separate": true
        },
        "disk",
        "btrfs",
        "zpool",
        {
            "type": "physicaldisk",
            "temp": true
        },
        "diskio",
        {
            "type": "battery",
            "temp": true
        },
        "poweradapter",
        "break",

        {
            "type": "separator",
            "string": "━━ Network ━━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        {
            "type": "publicip",
            "timeout": 1000
        },
        {
            "type": "localip",
            "showIpv6": true,
            "showMac": true,
            "showSpeed": true,
            "showMtu": true,
            "showLoop": true,
            "showFlags": true,
            "showAllIps": true
        },
        "dns",
        "wifi",
        "netio",
        "break",

        {
            "type": "separator",
            "string": "━━ Media ━━━━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        "player",
        "media",
        "sound",
        "break",

        {
            "type": "separator",
            "string": "━━ Peripherals ━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        "bluetooth",
        "bluetoothradio",
        "camera",
        "gamepad",
        "mouse",
        "keyboard",
        "break",

        {
            "type": "separator",
            "string": "━━ Graphics ━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        "vulkan",
        "opengl",
        "opencl",
        "break",

        {
            "type": "separator",
            "string": "━━ Other ━━━━━━━━━━━━━━━━━━━",
            "times": 1,
            "outputColor": "34"
        },
        "users",
        "tpm",
        "bios",
        "bootmgr",
        "board",
        "chassis",
        "initsystem",
        "loadavg",
        "processes",
        "editor",
        "terminalsize",
        "terminaltheme",
        {
            "type": "weather",
            "timeout": 1000
        },
        "version",

        "break",
        "colors"
    ]
}
