
{
    "layer": "top",
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 0,

    "include": [
        "~/.config/waybar/modules.json"
    ],

    "modules-left": [
        "custom/appmenu",
        "wlr/taskbar",
        "niri/window"
    ],

    "modules-center": [
        "niri/workspaces"
    ],

    "modules-right": [
