{
  // Workspaces
  "niri/workspaces": {
    "on-click": "activate"
  },

  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["Alacritty", "kitty", "ghostty"],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },

  // niri Window
  "niri/window": {
    "format": "{}",
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  // Empty
  "custom/empty": {
    "format": ""
  },

    // Tools
  "custom/tools": {
    "format": "п—Ҫ",
    "tooltip-format": "Tools"
  },

  // Updates Count
  //"custom/updates": {
  //    "format": "{} {icon}",
  //    "return-type": "json",
  //   "format-icons": {
  //        "has-updates": "уұҚ·",
  //        "updated": "у°ӮӘ"
  //    },
  //    "exec-if": "which waybar-module-pacman-updates",
  //    "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300"
  //},

  // wofi Application Launcher
  "custom/appmenu": {
    "format": "   ",
    "on-click": "sleep 0.2;wofi -show drun -replace",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // wofi Application Launcher
  "custom/appmenuicon": {
    "format": "пҢғ",
    "on-click": "sleep 0.2;wofi -show drun -replace",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // Idle Inhibit (йҳ»жӯўиҮӘеҠЁй”ҒеұҸ)
  "custom/idle-inhibit": {
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/idle-inhibit.sh",
    "interval": 1,
    "on-click": "~/.config/waybar/scripts/idle-inhibit.sh toggle"
  },

  // Power Menu
  "custom/exit": {
    "format": " у°җҘ ",
    "on-click": "~/.config/waybar/scripts/power-menu.sh",
    "tooltip-format": "Power Menu"
  },

  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "пҖЈ",
      "unlocked": "пӮң"
    }
  },

  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  // Clock
  "clock": {
    "format": "{:%Y-%m-%d  %H:%M  %a}",
    "on-click": "ags -t calendar",
    "tooltip": false
  },

  "niri/language": {
    "format": "/ K {short}"
  },

  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% п—§ ",
    "format-plugged": "{capacity}% пҮҰ",
    "format-alt": "{time}  {icon}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["пү„ ", "пүғ ", "пүӮ ", "пүҒ ", "пүҖ "]
  },

  // Pulseaudio
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": "пҡ© ",
    "format-icons": {
      "headphones": "пҖҘ",
      "handsfree": "п–җ",
      "headset": "п–җ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": ["пҖҰ", "пҖ§", "пҖЁ"]
    },
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "on-click-right": "pavucontrol"
  },

  // Bluetooth
  "bluetooth": {
    "format": "{status} пҠ“",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // backlight:
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "оҺҚ",
      "оҸ”",
      "оҸ“",
      "оҸ’",
      "оҸ‘",
      "оҸҗ",
      "оҸҸ",
      "оҸҺ",
      "оҸҚ",
      "оҸҢ",
      "оҸӢ",
      "оҸҠ",
      "оҸү",
      "оҸҲ",
      "оҺӣ"
    ],
    "scroll-step": 1
  }
}
